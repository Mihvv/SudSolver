{
  "categories": [
    {
      "title": "## Features",
      "title_prefix_pattern": "feat.*"
    },
    {
      "title": "## Bug Fixes",
      "title_prefix_pattern": "fix.*"
    },
    {
      "title": "## Chores",
      "title_prefix_pattern": "(ci|chore|cd).*"
    },
    {
      "title": "## Refactor",
      "title_prefix_pattern": "refactor.*"
    }
  ],
  "pr_template": "- ${{TITLE}}",
  "commit_template": "- ${{TITLE}}",
  "empty_template": "- no changes",
  "exclude_merge_branches": [
    "HEAD"
  ]
}